# Spotiseek — variáveis de ambiente.
# Copie para .env (cp .env.example .env) e preencha. NUNCA versione o .env real.
#
#   Gerar segredos:   openssl rand -hex 32
#   O scripts/install.sh gera os segredos faltantes automaticamente.

# ---------------------------------------------------------------------------------------------
# Banco de dados (SQLite — arquivo único; não precisa configurar nada externo)
# ---------------------------------------------------------------------------------------------
# Mantenha como está; o arquivo vive no volume app-data montado em /data.
DATABASE_URL=file:/data/spotiseek.db

# ---------------------------------------------------------------------------------------------
# Segredos da aplicação (obrigatórios) — gere com:  openssl rand -hex 32
# ---------------------------------------------------------------------------------------------
JWT_SECRET=                 # assina os tokens de sessão da UI
APP_SECRET=                 # cifra os tokens OAuth do Spotify em repouso

# ---------------------------------------------------------------------------------------------
# Conta admin inicial (criada no primeiro boot)
# ---------------------------------------------------------------------------------------------
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=             # troque por uma senha forte

# ---------------------------------------------------------------------------------------------
# Spotify — registre SEU PRÓPRIO app em https://developer.spotify.com/dashboard
#   1. "Create app" -> copie o Client ID e o Client Secret.
#   2. Em "Redirect URIs", adicione EXATAMENTE o valor de SPOTIFY_REDIRECT_URI abaixo
#      (troque localhost pelo host/IP onde a app roda, se for acessar pela LAN).
#   Cada instância usa a própria quota -> contorna o limite de Development Mode (ver docs/09).
# ---------------------------------------------------------------------------------------------
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8080/api/spotify/callback

# ---------------------------------------------------------------------------------------------
# Soulseek / slskd
#   - SOULSEEK_USERNAME/PASSWORD: crie uma conta UMA VEZ no cliente oficial (SoulseekQt) ou
#     diretamente; é a conta usada pelo slskd para logar na rede.
#   - SLSKD_API_KEY: chave interna entre o app e o slskd. Gere com:  openssl rand -hex 32
#     (a mesma chave é lida pelo slskd.yml e pelo app).
# ---------------------------------------------------------------------------------------------
SOULSEEK_USERNAME=
SOULSEEK_PASSWORD=
SLSKD_API_KEY=

# URL interna do slskd na rede do compose (não precisa mudar).
SLSKD_URL=http://slskd:5030

# ---------------------------------------------------------------------------------------------
# ONDE GUARDAR A MÚSICA (caminhos no HOST — bind mount)
#   MUSIC_PATH   : biblioteca final organizada (Artista/Álbum/NN Título.ext). É AQUI que sua
#                  coleção fica. No Raspberry, aponte para o seu disco:
#                      MUSIC_PATH=/home/pi/airdisk/Airdisk/Music
#   STAGING_PATH : área temporária onde o slskd baixa antes do app organizar. Use o MESMO
#                  drive que MUSIC_PATH para a organização ser um "rename" rápido (sem copiar
#                  entre discos). Ex.: /home/pi/airdisk/Airdisk/.spotiseek-staging
#   Os caminhos precisam existir e ser graváveis pelo container (ver nota de permissões no
#   docs/06). Se não definir, caem em ./music e ./downloads na pasta do projeto.
# ---------------------------------------------------------------------------------------------
MUSIC_PATH=./music
STAGING_PATH=./downloads

# (Internos do container — NÃO precisa mexer; já fixos no docker-compose.yml: /music e /downloads)
